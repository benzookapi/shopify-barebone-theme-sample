{% doc %}
  Method C: Breadcrumb navigation driven by metafields defined on products and collections.

  Metafield setup in Shopify admin (Settings > Custom data):
    - Namespace & key : custom.breadcrumb_path
      Type            : Single line text
      Description     : Pipe-separated ancestor labels, shallowest first.
      Example value   : Clothing|Women|Tops|Cut & Sew

    - Namespace & key : custom.breadcrumb_urls
      Type            : Single line text
      Description     : Pipe-separated ancestor URLs matching breadcrumb_path order.
      Example value   : /collections/clothing|/collections/women|/collections/tops|/collections/cut-and-sew

  Both metafields must have the same number of pipe-delimited segments.
  The current page (product or collection title + URL) is appended automatically.

  Usage:
    {% render 'breadcrumbs-metafield' %}

  Works on product pages and collection pages.
  Falls back gracefully when metafields are not set.

  @example
  {% render 'breadcrumbs-metafield' %}
{% enddoc %}

{%- liquid
  assign bc_path_raw = ''
  assign bc_urls_raw = ''

  if template.name == 'product'
    assign bc_path_raw = product.metafields.custom.breadcrumb_path.value | default: ''
    assign bc_urls_raw = product.metafields.custom.breadcrumb_urls.value | default: ''
    assign bc_current_title = product.title
    assign bc_current_url = product.url
  elsif template.name == 'collection'
    assign bc_path_raw = collection.metafields.custom.breadcrumb_path.value | default: ''
    assign bc_urls_raw = collection.metafields.custom.breadcrumb_urls.value | default: ''
    assign bc_current_title = collection.title
    assign bc_current_url = collection.url
  elsif template.name == 'article'
    assign bc_current_title = article.title
    assign bc_current_url = article.url
  elsif template.name == 'page'
    assign bc_current_title = page.title
    assign bc_current_url = page.url
  else
    assign bc_current_title = page_title
    assign bc_current_url = request.path
  endif

  assign bc_labels = bc_path_raw | split: '|'
  assign bc_urls   = bc_urls_raw | split: '|'
-%}

<nav aria-label="breadcrumb" class="breadcrumbs breadcrumbs--metafield">
  <ol class="breadcrumbs__list" itemscope itemtype="https://schema.org/BreadcrumbList">

    <li class="breadcrumbs__item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
      <a class="breadcrumbs__link" href="{{ routes.root_url }}" itemprop="item">
        <span itemprop="name">{{ 'general.breadcrumbs.home' | t | default: 'Home' }}</span>
      </a>
      <meta itemprop="position" content="1">
    </li>

    {%- for label in bc_labels -%}
      {%- assign crumb_url = bc_urls[forloop.index0] | default: '' -%}
      {%- assign position = forloop.index | plus: 1 -%}

      <li class="breadcrumbs__item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        {%- if crumb_url != blank -%}
          <a class="breadcrumbs__link" href="{{ crumb_url }}" itemprop="item">
            <span itemprop="name">{{ label }}</span>
          </a>
        {%- else -%}
          <span class="breadcrumbs__label" itemprop="name">{{ label }}</span>
        {%- endif -%}
        <meta itemprop="position" content="{{ position }}">
      </li>
    {%- endfor -%}

    {%- assign current_position = bc_labels.size | plus: 2 -%}
    <li class="breadcrumbs__item breadcrumbs__item--current"
        itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
      <span class="breadcrumbs__current" itemprop="name" aria-current="page">{{ bc_current_title }}</span>
      <meta itemprop="position" content="{{ current_position }}">
    </li>

  </ol>
</nav>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": {{ 'general.breadcrumbs.home' | t | default: 'Home' | json }},
      "item": {{ shop.url | append: routes.root_url | json }}
    }
    {%- for label in bc_labels -%}
      {%- assign crumb_url = bc_urls[forloop.index0] | default: '' -%}
      ,{
        "@type": "ListItem",
        "position": {{ forloop.index | plus: 1 }},
        "name": {{ label | json }}
        {%- if crumb_url != blank -%}
        ,"item": {{ shop.url | append: crumb_url | json }}
        {%- endif -%}
      }
    {%- endfor -%}
    ,{
      "@type": "ListItem",
      "position": {{ bc_labels.size | plus: 2 }},
      "name": {{ bc_current_title | json }},
      "item": {{ shop.url | append: bc_current_url | json }}
    }
  ]
}
</script>

{% stylesheet %}
  .breadcrumbs {
    padding: 0.5rem 0;
  }

  .breadcrumbs__list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: 0.875rem;
  }

  .breadcrumbs__item + .breadcrumbs__item::before {
    content: '/';
    color: currentColor;
    opacity: 0.4;
    margin-right: 0.25rem;
  }

  .breadcrumbs__link {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .breadcrumbs__link:hover {
    opacity: 0.7;
  }

  .breadcrumbs__label {
    opacity: 0.6;
  }

  .breadcrumbs__current {
    opacity: 0.6;
  }
{% endstylesheet %}
